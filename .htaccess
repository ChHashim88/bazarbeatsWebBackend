# Hostinger / Phusion Passenger Configuration
# ---------------------------------------------------------
# Automatically updated with your actual server path

PassengerAppRoot "/home/u397983207/domains/api.bazarbeats.com/nodejs"
PassengerBaseURI "/"
PassengerAppType node
PassengerStartupFile index.cjs

# LiteSpeed Specific Rules
<IfModule Litespeed>
    RewriteEngine On
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ / [L]
</IfModule>

# Security: Disable directory browsing
Options -Indexes

# Increase timeouts
<IfModule mod_env.c>
    SetEnv MAGICK_THREAD_LIMIT 1
</IfModule>
